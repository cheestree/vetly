{
  "name": "vetly-frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:local": "dotenv -e .env.local -- expo start",
    "start:docker": "dotenv -e .env.docker -- expo start",
    "android": "dotenv -e .env.local -- expo run:android",
    "tunnel": "expo start --tunnel",
    "dev": "concurrently \"expo start --tunnel\" \"ngrok http 8080\"",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "devices": "expo run:android --no-build-cache --device",
    "test": "jest --watchAll",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "npm run lint:fix"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^23.7.0",
    "@react-native-firebase/auth": "^23.7.0",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.3.9",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/stack": "^7.3.1",
    "@types/react": "~19.1.10",
    "axios": "^1.12.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~56.0.13",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.10.0",
    "mime": "^4.0.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-mmkv": "^4.2.0",
    "react-native-paper": "^5.14.5",
    "react-native-paper-dates": "^0.22.51",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "toastify-react-native": "^7.2.3",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.53.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "ngrok": "^5.0.0-beta.2",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3"
  },
  "private": true
}
